DATABASE_URL=postgresql://megacorps:megacorps_dev_password@postgres:5432/megacorps
# Required in production: stable random value, at least 32 characters.
# Generate one with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
# Optional one-shot first-admin bootstrap token. Remove after bootstrap.
BOOTSTRAP_TOKEN=
COOKIE_SECURE=false
SIGNUP_ENABLED=false
SIGNUP_ATTACH_DEFAULT_COMPANY=false
SIGNUP_DEFAULT_ROLE=viewer
SIGNUP_DEFAULT_COMPANY_ROLE=viewer
PORTAINER_URL=
PORTAINER_USER=admin
PORTAINER_PASS=replace-me
PORTAINER_ENDPOINT_ID=4
HERMES_CONTAINER=hermes-suite
HERMES_GATEWAY_URL=
HERMES_DASHBOARD_TOKEN=
HERMES_SSH_HOST=
HERMES_SSH_USER=root
HERMES_SSH_PORT=22
HERMES_SSH_KEY_PATH=
HERMES_SSH_COMMAND=hermes
HERMES_SSH_OPTIONS=
ADAPTER_ENV_FALLBACK_ENABLED=false
ADAPTER_TARGET_ALLOWLIST=
WEBHOOK_ADAPTER_URL=
OPENCLAW_WEBHOOK_URL=
WEBHOOK_SHARED_SECRET=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_PER_MINUTE=12
RATE_LIMIT_CHAT_PER_MINUTE=40
RATE_LIMIT_WEBHOOK_PER_MINUTE=120
RATE_LIMIT_OPERATOR_PER_MINUTE=20
RATE_LIMIT_WRITE_PER_MINUTE=120
RATE_LIMIT_READ_PER_MINUTE=600
TRUST_PROXY=false
DISPATCH_LOOP_ENABLED=true
DISPATCH_LOOP_INTERVAL_MS=30000
BUDGET_RESET_ENABLED=true
BUDGET_RESET_DAY=1
TASK_RUN_WORKER_ENABLED=true
TASK_RUN_WORKER_INTERVAL_MS=2000
TASK_RUN_WORKER_BATCH_SIZE=2
TASK_RUN_WORKER_ID=megacorps-server
DISPATCH_CONTEXT_CHAR_BUDGET=32000
DISPATCH_CONTEXT_CARD_LIMIT=160
DISPATCH_CONTEXT_RECORD_LIMIT=30
DISPATCH_TASK_BODY_CHAR_LIMIT=12000
DISPATCH_KNOWLEDGE_DOC_CHAR_LIMIT=4000
MESSAGE_BOARD_COMMENT_LIMIT=20000
NEXT_PUBLIC_API_URL=http://localhost:4000
